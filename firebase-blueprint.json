{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A 3D visualization project with images and optional 3D models.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Display name of the project" },
        "category": { "type": "string", "description": "Category: INTERIOR, EXTERIOR, or PRODUCT" },
        "imageUrl": { "type": "string", "description": "Primary display image URL" },
        "modelUrl": { "type": "string", "description": "Optional URL to a .glb or .gltf file" },
        "description": { "type": "string", "description": "Short description of the work done" },
        "year": { "type": "string", "description": "Year of completion" },
        "ownerId": { "type": "string", "description": "UID of the creator" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "imageUrl", "ownerId", "createdAt"]
    }
  },
  "firestore": {
    "projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of all portfolio projects."
    }
  }
}
